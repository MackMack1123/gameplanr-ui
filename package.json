{
  "name": "@gameplanr/ui",
  "version": "2.0.1",
  "description": "GamePlanr v3 design system — shared tokens, Tailwind preset, and components.",
  "repository": {
    "type": "git",
    "url": "https://github.com/MackMack1123/gameplanr-ui.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tailwind.preset": {
      "types": "./dist/tailwind.preset.d.ts",
      "import": "./dist/tailwind.preset.mjs",
      "require": "./dist/tailwind.preset.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://gitea.mvp-labs.com/api/packages/brm5017/npm/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18",
    "react": "^18",
    "react-dom": "^18",
    "tsup": "^8",
    "typescript": "^5"
  }
}
